# ─────────────────────────────────────────────────────────────
# AutoImport — variáveis de ambiente (exemplo)
# Copiar para .env.local e preencher. NUNCA commitar segredos reais.
# O frontend corre com dados MOCK sem precisar de nada disto (ver
# docs/07-FRONTEND-HANDOFF.md). Estas variáveis são para o backend.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Base de dados (Supabase / Postgres) — ver docs/04-BASE-DE-DADOS.md
# Supabase → Project Settings → Database → Connection string (usar o pooler
# "Transaction", porta 6543). Depois: `pnpm db:migrate` aplica as migrations.
# Dev local sem Supabase: `pnpm db:up` (docker) e usar
#   DATABASE_URL="postgresql://autoimport:autoimport@localhost:54329/autoimport"
DATABASE_URL=""

# Auth (Better Auth) — ver docs/03-BACKEND.md
# Gerar o secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Login com Google (OPCIONAL) — o botão só aparece se as duas existirem.
# Criar em console.cloud.google.com → APIs & Services → Credentials →
# Create credentials → OAuth client ID → Web application.
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google                 (dev)
#   https://autoimport.arestadigital.pt/api/auth/callback/google   (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Pagamentos (Polar) — ver docs/06-SERVICOS-EXTERNOS.md
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""

# Email (Resend) — sem chave, os emails não são enviados e o link de reset
# aparece no log do servidor (suficiente para desenvolvimento).
RESEND_API_KEY=""
# Remetente. Tem de ser um domínio verificado no Resend.
# Para testar sem domínio verificado: "AutoImport <onboarding@resend.dev>"
EMAIL_FROM="AutoImport <ola@autoimport.arestadigital.pt>"

# IA (Anthropic Claude) — normalização de anúncios na engine
ANTHROPIC_API_KEY=""

# Observabilidade
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
