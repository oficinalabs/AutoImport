{
  "name": "autoimport",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck:tools": "tsc -p tools/collector/tsconfig.json",
    "typecheck:net-capture": "tsc -p tools/net-capture/tsconfig.json",
    "auth:generate": "npx @better-auth/cli generate --config lib/auth.ts --output db/schema.ts --yes",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/db/seed.ts",
    "pipeline:daily": "tsx scripts/pipeline/run-daily.ts",
    "pipeline:ingest": "tsx scripts/pipeline/ingest.ts",
    "db:migrate:deploy": "tsx scripts/db/migrate-deploy.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-query": "^5.62.7",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "next-themes": "^0.4.4",
    "postgres": "^3.4.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "resend": "^6.17.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2"
  }
}
